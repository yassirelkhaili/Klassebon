{
  "name": "backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace=@klassebon/shared && prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "tsx src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run --exclude test/ocr-integration.test.ts",
    "test:watch": "vitest --exclude test/ocr-integration.test.ts",
    "test:integration": "vitest run test/ocr-integration.test.ts"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.5",
    "@klassebon/shared": "*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@trpc/server": "^11.12.0",
    "better-auth": "^1.5.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.11",
    "prisma": "^7.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.3"
  }
}
